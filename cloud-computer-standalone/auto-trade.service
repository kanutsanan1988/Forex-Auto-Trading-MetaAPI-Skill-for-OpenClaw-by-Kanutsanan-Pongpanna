[Unit]
Description=Auto Trade XAUUSD System
After=network.target

[Service]
Type=oneshot
User=root
WorkingDirectory=/opt/auto-trade
ExecStart=/opt/auto-trade/venv/bin/python /opt/auto-trade/auto_trade.py
StandardOutput=append:/var/log/auto_trade_systemd.log
StandardError=append:/var/log/auto_trade_systemd.log

[Install]
WantedBy=multi-user.target
