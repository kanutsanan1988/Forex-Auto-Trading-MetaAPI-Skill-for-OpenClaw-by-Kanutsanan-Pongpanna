# ====================================================
# Kanutsanan-Pongpanna Agentic AI Auto Trading Config
# ====================================================
# 
# ⚠️  IMPORTANT SECURITY NOTES:
# 1. NEVER share your API Key or Account ID
# 2. NEVER commit .env to git/version control
# 3. Keep this file private and secure
# 4. Use strong passwords and 2FA on MetaApi account
#
# ====================================================

# MetaApi API Key
# Get from: https://app.metaapi.cloud/account/settings
# Look for: "API Token" or "Access Token"
export TOKEN="YOUR_METAPI_API_KEY_HERE"

# MetaApi Account ID
# Get from: https://app.metaapi.cloud
# Go to: Select your MT5 account → Account ID
export ACCOUNT_ID="YOUR_ACCOUNT_ID_HERE"

# ====================================================
# Optional Settings
# ====================================================

# Trading Symbol (default: XAUUSD.sml - Gold micro)
# XAUUSD.sml = Gold (Micro lot)
# EURUSD = Euro/Dollar
# GBPUSD = British Pound/Dollar
export SYMBOL="XAUUSD.sml"

# Risk Percentage per Trade (default: 2%)
# 0.02 = 2% of balance per trade
export RISK_PERCENT="0.02"

# Maximum SL Points (default: 100)
# If SL > this, trade is rejected
export MAX_SL_POINTS="100"

# Minimum Signal Strength (default: 4/10)
# Trade is rejected if signal < this
export MIN_SIGNAL_STRENGTH="4"

# Profit Threshold Percentage (default: 2%)
# Position management uses ±2% thresholds
export PROFIT_THRESHOLD="2"

# Daily Loss Limit (default: -20%)
# Trading halts if daily loss exceeds this
export DAILY_LOSS_LIMIT="-20"

# Minimum Equity Required (default: $0.10)
# Must have at least this equity to trade
export MIN_EQUITY="0.10"

# Minimum Balance Required (default: $0.05)
# Must have at least this balance to trade
export MIN_BALANCE="0.05"

# ====================================================
# Logging Configuration
# ====================================================

# Log File Path (optional)
# export LOG_FILE="/var/log/forex-trading.log"

# Log Level (optional)
# Values: DEBUG, INFO, WARN, ERROR
# export LOG_LEVEL="INFO"

# ====================================================
# Setup Instructions
# ====================================================
#
# 1. Fill in your MetaApi credentials:
#    - TOKEN: Your API Key
#    - ACCOUNT_ID: Your MT5 Account ID
#
# 2. Save this file as .env in your project root:
#    cp assets/config-template.env .env
#
# 3. Load environment variables:
#    source .env
#
# 4. Run trade check:
#    node scripts/kanutsanan-pongpanna-trade-check-template.js
#
# 5. Or run full auto (if working well):
#    node scripts/kanutsanan-pongpanna-full-auto-template.js &
#
# ====================================================
