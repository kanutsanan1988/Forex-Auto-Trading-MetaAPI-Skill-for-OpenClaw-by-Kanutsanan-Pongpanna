# Forex Auto Trading System - Environment Configuration
# Copy this file to .env and fill in your actual API keys
# DO NOT commit .env file to version control!

# MetaAPI Configuration
# Get your token from: https://app.metaapi.cloud/
METAAPI_TOKEN=YOUR_METAAPI_TOKEN_HERE

# Your MetaAPI Account ID
# Get your account ID from: https://app.metaapi.cloud/accounts
METAAPI_ACCOUNT_ID=YOUR_METAAPI_ACCOUNT_ID_HERE

# OpenRouter API Key
# Get your API key from: https://openrouter.ai/
# Used for AI analysis (google/gemini-2.5-flash)
OPENROUTER_API_KEY=YOUR_OPENROUTER_API_KEY_HERE

# Optional: Logging Configuration
# Default log file location (requires sudo for /var/log)
# LOG_FILE=/var/log/auto_trade.log
