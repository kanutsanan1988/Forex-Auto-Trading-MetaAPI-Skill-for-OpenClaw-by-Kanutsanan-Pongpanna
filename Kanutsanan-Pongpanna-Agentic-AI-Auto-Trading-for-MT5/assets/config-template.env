# Auto Trade System - Environment Variables
# MetaAPI Credentials
METAAPI_ACCOUNT_ID=YOUR_METAAPI_ACCOUNT_ID_HERE
METAAPI_TOKEN=YOUR_METAAPI_TOKEN_HERE

# OpenRouter API Key
OPENROUTER_API_KEY=YOUR_OPENROUTER_API_KEY_HERE

# Trading Configuration
SYMBOL=XAUUSD.sml
MAX_MARGIN_PERCENT=50
MIN_LOT=0.001
MAX_LOT=0.1
MIN_STRENGTH=6
TRADE_INTERVAL_MINUTES=10

# OpenRouter Model
AI_MODEL=google/gemini-2.5-flash
